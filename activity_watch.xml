<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.media3.ui.PlayerView
            android:id="@+id/player_view"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@android:color/black"
            app:resize_mode="fit" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_watch_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Judul Video Sedang Dimuat..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tv_watch_views"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0x ditonton"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btn_like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suka (0)"
                    android:backgroundTint="#E0E0E0"
                    android:textColor="@android:color/black"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_share"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bagikan"
                    android:backgroundTint="#E0E0E0"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_watch_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori: Memuat..."
                android:textSize="14sp"
                android:textColor="#007bff"
                android:layout_marginTop="12dp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn_download_normal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Download Video"
                android:backgroundTint="#4CAF50"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btn_download_full"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Download Full (Buka di Browser)"
                android:backgroundTint="#FF9800"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Video Terkait"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_random_videos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
